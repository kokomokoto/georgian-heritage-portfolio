# Virtual Environment
.venv/
venv/
env/

# Environment Variables - NEVER COMMIT THESE!
.env
.env.local
.env.production
.env.staging

# Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Local database
instance/
*.db

# Legacy JSON backups (may contain production data)
projects.json
comments.json
_all_dev_db_projects.json
_production_projects_full.json

# Logs
*.log
upload_debug.log

# Local uploads (don't commit user uploads)
projects/*/
uploads/
static/uploads/

# Keep project structure but not content
!projects/.gitkeep
!uploads/.gitkeep
!static/uploads/.gitkeep

# Static site build artifacts
_cloudflare_static/
